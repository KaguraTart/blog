---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Kagura Tart 的博客' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} | KaguraTart</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg-base: #0a0a0f;
        --bg-card: rgba(255,255,255,0.04);
        --bg-card-hover: rgba(255,255,255,0.07);
        --border: rgba(255,255,255,0.08);
        --border-accent: rgba(124,111,248,0.4);
        --text-primary: #e8e8f0;
        --text-secondary: #8888a0;
        --text-muted: #555568;
        --accent: #7c6ff8;
        --accent-dim: rgba(124,111,248,0.15);
        --accent-glow: rgba(124,111,248,0.3);
        --shadow: rgba(0,0,0,0.4);
      }

      /* Light Mode */
      html.light {
        --bg-base: #f8f9fa;
        --bg-card: rgba(0,0,0,0.04);
        --bg-card-hover: rgba(0,0,0,0.07);
        --border: rgba(0,0,0,0.1);
        --border-accent: rgba(124,111,248,0.3);
        --text-primary: #1a1a2e;
        --text-secondary: #555568;
        --text-muted: #999;
        --accent: #7c6ff8;
        --accent-dim: rgba(124,111,248,0.1);
        --accent-glow: rgba(124,111,248,0.2);
        --shadow: rgba(0,0,0,0.1);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg-base);
        color: var(--text-primary);
        min-height: 100vh;
        overflow-x: hidden;
      }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(124,111,248,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(124,111,248,0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
        background-attachment: fixed;
      }
      html.light body::before {
        background-image:
          linear-gradient(rgba(124,111,248,0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(124,111,248,0.06) 1px, transparent 1px);
      }
      body::after {
        content: '';
        position: fixed;
        top: -30%;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 800px;
        background: radial-gradient(ellipse, rgba(124,111,248,0.12) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
        background-attachment: fixed;
      }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg-base); }
      ::-webkit-scrollbar-thumb { background: var(--border-accent); border-radius: 3px; }
      ::selection { background: var(--accent-dim); color: var(--text-primary); }

      /* Nav */
      nav {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 720px;
        margin: 0 auto;
        padding: 1.5rem 2rem;
      }
      .nav-logo {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-primary);
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .nav-links {
        display: flex;
        gap: 1.5rem;
        list-style: none;
      }
      .nav-links a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 400;
        transition: color 0.2s;
      }
      .nav-links a:hover,
      .nav-links a.active { color: var(--text-primary); }

      /* ===== Theme Toggle Button ===== */
      .theme-toggle {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text-primary);
        padding: 0.4rem 0.6rem;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        margin-left: 1rem;
        flex-shrink: 0;
      }
      .theme-toggle:hover {
        background: var(--bg-card-hover);
        border-color: var(--accent);
        transform: scale(1.05);
      }
      .theme-toggle .sun { display: none; }
      .theme-toggle .moon { display: inline; }
      html.light .theme-toggle .sun { display: inline; }
      html.light .theme-toggle .moon { display: none; }

      /* Light mode article adjustments */
      html.light body { background: var(--bg-base); color: var(--text-primary); }
      html.light .bg-gradient { background: linear-gradient(135deg, #f8f9fa 0%, #e8e8ff 100%) !important; }
      html.light .page-wrapper { background: transparent; }
      html.light .article { background: rgba(255,255,255,0.8); border-color: var(--border); }
      html.light .post-card { background: rgba(255,255,255,0.6); border-color: var(--border); }
      html.light .article-content code { background: rgba(124,111,248,0.08); }
      html.light .article-content pre { background: #1a1a2e; }
      html.light .tag { background: var(--accent-dim); color: var(--accent); }

      /* ===== Mobile Responsive ===== */
      @media (max-width: 768px) {
        nav { padding: 1rem; }
        .page-wrapper { padding: 0; }
        .header { padding: 1.5rem 1rem; }
        .header .title { font-size: 2rem !important; }
        .posts { padding: 0 1rem; }
        .post-card { padding: 1.25rem !important; }
        .article-title { font-size: 1.5rem !important; }
        .article-content { padding: 1.5rem 1rem !important; font-size: 0.9rem !important; }
        .article-content pre { font-size: 0.8rem !important; padding: 1rem !important; }
        .article-content img { max-width: 100% !important; height: auto !important; display: block; margin: 0 auto; }
      }
      @media (max-width: 480px) {
        nav { padding: 0.75rem; }
        .header { padding: 1rem 0.75rem; }
        .header .title { font-size: 1.6rem !important; }
        .article-content { font-size: 0.88rem !important; line-height: 1.7 !important; }
        .article-content h1 { font-size: 1.3rem !important; }
        .article-content h2 { font-size: 1.1rem !important; }
        .article-content pre { font-size: 0.75rem !important; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo">Kagura Tart</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </nav>
    <slot />
  <script is:inline>
    // Theme management
    function getTheme() {
      return localStorage.getItem('theme') || 'dark';
    }
    function setTheme(theme) {
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
      localStorage.setItem('theme', theme);
    }
    function toggleTheme() {
      const current = getTheme();
      setTheme(current === 'dark' ? 'light' : 'dark');
    }
    // Init on load
    setTheme(getTheme());
    // Listen for system preference changes
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        setTheme(e.matches ? 'light' : 'dark');
      }
    });
  </script>
  </body>
</html>

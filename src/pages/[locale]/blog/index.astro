---
import BlogIndexPage from '../../../components/BlogIndexPage.astro';
import { routeLocales } from '../../../i18n/config.mjs';

export function getStaticPaths() {
  return routeLocales.map(locale => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;
---

<BlogIndexPage locale={locale} />

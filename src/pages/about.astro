---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About Me" description="About Deng Diantao (邓典涛)">
  <div class="about-wrapper">
    <header class="about-header">
      <div class="lang-toggle-wrap">
        <a href="#" class="lang-toggle active" data-lang="en">EN</a>
        <span class="lang-sep">/</span>
        <a href="#" class="lang-toggle" data-lang="zh">中文</a>
      </div>
      <a href="/blog" class="back-link">← Blog</a>
      <h1 class="about-title" data-i18n="title">About Me</h1>
      <p class="about-subtitle" data-i18n="subtitle">邓典涛 / Deng Diantao</p>
    </header>

    <div class="about-content">

      <!-- 个人简介 / Introduction -->
      <section class="section">
        <h2 data-i18n-label="bio">👤 About</h2>
        <div class="lang-content" data-lang="en">
          <p>Ph.D. candidate at Beihang University (BUAA), School of Transportation Science and Engineering. M.Sc. at Tongji University, College of Transportation Engineering. Previously interned at Huawei Vehicle BU and Bosch China.</p>
        </div>
        <div class="lang-content" data-lang="zh" style="display:none">
          <p>北京航空航天大学交通科学与工程学院在读博士，研究方向为自动驾驶与交通仿真。同济大学交通运输工程硕士。同济大学土木工程学士。曾于华为车BU、博世中国实习。</p>
        </div>
      </section>

      <!-- 教育背景 / Education -->
      <section class="section">
        <h2 data-i18n-label="edu">🎓 Education</h2>
        <div class="edu-item">
          <div class="edu-header">
            <strong data-i18n="edu1_school">Beihang University (BUAA)</strong>
            <span class="edu-date">2024 – Present</span>
          </div>
          <div class="edu-sub">Ph.D. · Transportation Science & Engineering</div>
        </div>
        <div class="edu-item">
          <div class="edu-header">
            <strong data-i18n="edu2_school">Tongji University</strong>
            <span class="edu-date">2021 – 2024</span>
          </div>
          <div class="edu-sub">M.Sc. · Transportation Engineering</div>
          <div class="edu-courses">Courses: Computer Aided Design, Transportation Data Analysis, Numerical Computation, Data Mining</div>
        </div>
        <div class="edu-item">
          <div class="edu-header">
            <strong data-i18n="edu3_school">Tongji University</strong>
            <span class="edu-date">2017 – 2021</span>
          </div>
          <div class="edu-sub">B.Eng. · Civil Engineering</div>
          <div class="edu-courses">Courses: Finite Element Method, Calculus, Linear Algebra, Probability & Statistics, C++</div>
          <div class="edu-award">Awards: 2020 Campus Scholarship, 2018 Kaisa Scholarship</div>
        </div>
      </section>

      <!-- 工作经历 / Experience -->
      <section class="section">
        <h2 data-i18n-label="exp">💼 Experience</h2>
        <div class="exp-item">
          <div class="exp-header">
            <strong>Shanghai Yinwang Intelligence (Huawei Vehicle BU)</strong>
            <span class="exp-date">2024.07 – Present</span>
          </div>
          <div class="exp-role">DevOps Engineer</div>
          <ul>
            <li>Extract CAN bus signals from onboard .MF4 data, parse and generate core dashboard JSON files</li>
            <li>Visualize vehicle perception data, convert to OpenX format and import into CarMaker for ADAS SIL testing</li>
            <li>Design automated test cases for autonomous driving and parking edge cases using CarMaker and CARLA</li>
          </ul>
        </div>
        <div class="exp-item">
          <div class="exp-header">
            <strong>Bosch (China) Investment Ltd.</strong>
            <span class="exp-date">2023.07 – 2023.12</span>
          </div>
          <div class="exp-role">Strategy Intern (Deep Learning)</div>
          <ul>
            <li>Researched point cloud characteristics of mmWave Radar and LiDAR using KITTI, Waymo and private datasets</li>
            <li>Used GNN graph generation to synthesize diverse trajectories, output .xodr and .xosc HD map formats for simulation</li>
          </ul>
        </div>
      </section>

      <!-- 项目经历 / Projects -->
      <section class="section">
        <h2 data-i18n-label="proj">🚀 Projects</h2>
        <div class="project-item">
          <div class="project-header">
            <strong>Driving Simulation & Traffic Simulation Fusion Platform</strong>
            <span class="project-role">Software Engineer · 2021.09 – 2024.06</span>
          </div>
          <ul>
            <li>Integrated CARLA (Unreal Engine) and SUMO traffic simulation via TCP/IP; Python scripts for vehicle control, traffic generation and data analysis</li>
            <li>Compiled SUMO with gcc on Ubuntu; improved lane-changing model to match real-world data distributions</li>
            <li>Used YOLOv3 for vehicle detection, trajectory extraction, and Kalman filtering for data smoothing</li>
            <li>Real-time MySQL database for platform data with external API access</li>
          </ul>
        </div>
        <div class="project-item">
          <div class="project-header">
            <strong>RL-Based Urban Expressway Traffic State Optimization</strong>
            <span class="project-role">First Author · 2022.07 – 2023.04</span>
          </div>
          <ul>
            <li>Published SCI Q3 paper (Journal of Advanced Transportation); Q-learning for expressway ramp signal control</li>
            <li>SUMO-Python co-simulation for coordinated ramp metering and channelization control</li>
          </ul>
        </div>
        <div class="project-item">
          <div class="project-header">
            <strong>YOLOX-Based Road Pavement Disease Detection</strong>
            <span class="project-role">Team Lead · 2022.05 – 2022.06</span>
          </div>
          <ul>
            <li>Road pavement disease classification and prediction using YOLOX with data augmentation (flip, crop, rotate)</li>
            <li>Simplified model input; improved inference speed; Excellence Award winner</li>
          </ul>
        </div>
      </section>

      <!-- 论文 / Publications -->
      <section class="section">
        <h2 data-i18n-label="pub">📝 Publications</h2>
        <div class="pub-item">
          <p>
            <strong>Deng D, Yu B, Xu D, et al.</strong> Automated Traffic State Optimization in the Weaving Area of Urban Expressways by a Reinforcement Learning-Based Cooperative Method of Channelization and Ramp Metering[J]. 
            <em>Journal of Advanced Transportation</em>, 2023. (SCI Q3, IF = 2.3)
          </p>
        </div>
      </section>

      <!-- 专利 / Patents -->
      <section class="section">
        <h2 data-i18n-label="patent">💡 Patents</h2>
        <div class="pub-item">
          <p>
            <strong>Yu B, Chen Y, Deng D, Gao J, Yao S.</strong> A Traffic State Optimization Method and System in Road Interleaved Area[P]. Shanghai: CN202310359301.2, 2023-04-06.
          </p>
        </div>
      </section>

    </div>
  </div>
</Layout>

<script>
  // Language toggle
  const toggles = document.querySelectorAll('.lang-toggle');
  const contents = document.querySelectorAll('.lang-content');
  const labels = document.querySelectorAll('[data-i18n-label]');
  const i18nMap = {
    en: {
      title: 'About Me', subtitle: '邓典涛 / Deng Diantao', bio: '👤 About',
      edu: '🎓 Education', exp: '💼 Experience', proj: '🚀 Projects',
      pub: '📝 Publications', patent: '💡 Patents',
      back: '← Blog',
      edu1_school: 'Beihang University (BUAA)',
      edu2_school: 'Tongji University', edu3_school: 'Tongji University',
    },
    zh: {
      title: '关于我', subtitle: '邓典涛 / Deng Diantao', bio: '👤 个人简介',
      edu: '🎓 教育背景', exp: '💼 工作经历', proj: '🚀 项目经历',
      pub: '📝 论文发表', patent: '💡 发明专利',
      back: '← 博客',
      edu1_school: '北京航空航天大学',
      edu2_school: '同济大学', edu3_school: '同济大学',
    }
  };

  function setLang(lang) {
    // Save preference
    localStorage.setItem('about-lang', lang);
    // Toggle buttons
    toggles.forEach(t => t.classList.toggle('active', t.dataset.lang === lang));
    // Toggle content
    contents.forEach(c => c.style.display = c.dataset.lang === lang ? '' : 'none');
    // Update labels
    labels.forEach(el => {
      const key = el.dataset.i18nLabel;
      if (key && i18nMap[lang][key]) el.textContent = i18nMap[lang][key];
    });
    // Update title & subtitle
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      if (i18nMap[lang][key]) el.textContent = i18nMap[lang][key];
    });
    // Update back link
    document.querySelector('.back-link').textContent = i18nMap[lang].back;
    // Update section headers (dynamic based on current lang content)
    const edu1 = document.querySelector('[data-i18n="edu1_school"]');
    const edu2 = document.querySelector('[data-i18n="edu2_school"]');
    const edu3 = document.querySelector('[data-i18n="edu3_school"]');
    if (edu1) edu1.textContent = i18nMap[lang].edu1_school;
    if (edu2) edu2.textContent = i18nMap[lang].edu2_school;
    if (edu3) edu3.textContent = i18nMap[lang].edu3_school;
  }

  toggles.forEach(t => t.addEventListener('click', (e) => {
    e.preventDefault();
    setLang(t.dataset.lang);
  }));

  // Restore preference
  const saved = localStorage.getItem('about-lang') || 'en';
  setLang(saved);
</script>

<style>
  .about-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 2rem 5rem;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .about-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .lang-toggle-wrap {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
  }
  .lang-toggle {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    font-family: 'JetBrains Mono', monospace;
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
  }
  .lang-toggle:hover, .lang-toggle.active {
    color: var(--accent);
  }
  .lang-sep { color: var(--text-muted); }

  .about-title {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .about-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 300;
  }

  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 0.7; }

  .section { margin-bottom: 2.5rem; }
  .section h2 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .section p {
    color: var(--text-secondary);
    line-height: 1.85;
    font-size: 0.95rem;
    font-weight: 300;
  }

  .edu-item { margin-bottom: 1.25rem; padding: 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; }
  .edu-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; }
  .edu-header strong { color: var(--text-primary); font-size: 0.95rem; }
  .edu-date { color: var(--text-muted); font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; }
  .edu-sub { color: var(--accent); font-size: 0.85rem; margin-bottom: 0.5rem; }
  .edu-courses { color: var(--text-secondary); font-size: 0.82rem; margin-top: 0.3rem; }
  .edu-courses::before { content: '• '; }
  .edu-award { color: var(--text-muted); font-size: 0.82rem; margin-top: 0.3rem; font-style: italic; }
  .edu-award::before { content: '• '; }

  .exp-item { margin-bottom: 1.5rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; }
  .exp-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.25rem; gap: 1rem; }
  .exp-header strong { color: var(--text-primary); font-size: 0.95rem; }
  .exp-date { color: var(--text-muted); font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .exp-role { color: var(--accent); font-size: 0.85rem; margin-bottom: 0.75rem; }
  .exp-item ul, .project-item ul { padding-left: 1.2rem; margin: 0; }
  .exp-item li, .project-item li { color: var(--text-secondary); font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.4rem; font-weight: 300; }

  .project-item { margin-bottom: 1.5rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; }
  .project-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; gap: 1rem; }
  .project-header strong { color: var(--text-primary); font-size: 0.95rem; }
  .project-role { color: var(--text-muted); font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }

  .pub-item { padding: 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.75rem; }
  .pub-item p { color: var(--text-secondary); font-size: 0.88rem; line-height: 1.7; }

  /* Mobile */
  @media (max-width: 768px) {
    .about-wrapper { padding: 1rem 1rem 3rem !important; }
    .about-title { font-size: 1.8rem !important; }
    .edu-header, .exp-header, .project-header { flex-direction: column !important; gap: 0.25rem !important; }
    .edu-date, .exp-date, .project-role { font-size: 0.75rem !important; }
    .section h2 { font-size: 1.1rem !important; }
    .section p, .exp-item li, .project-item li { font-size: 0.85rem !important; }
    .lang-toggle-wrap { top: 0; }
  }

  /* Light mode */
  :global(html.light) .about-wrapper { background: transparent !important; }
  :global(html.light) .edu-item, :global(html.light) .exp-item, :global(html.light) .project-item, :global(html.light) .pub-item { background: rgba(255,255,255,0.6) !important; }
  :global(html.light) .about-title, :global(html.light) .edu-header strong, :global(html.light) .exp-header strong, :global(html.light) .project-header strong { color: #1a1a2e !important; }
  :global(html.light) .section h2 { color: #1a1a2e !important; border-color: rgba(0,0,0,0.1) !important; }
  :global(html.light) .back-link { color: #7c6ff8 !important; }
</style>

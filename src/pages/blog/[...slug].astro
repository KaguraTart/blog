---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="article-wrapper">
    <header class="article-header">
      <div class="article-meta-top">
        <a href="/blog" class="back-link glow-on-hover">← Blog</a>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-desc">{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="article-content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 2rem 5rem;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .article-header { margin-bottom: 3rem; }
  .article-meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .back-link {
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 0.7; }
  time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .article-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .article-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    color: var(--text-muted);
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-size: 0.78rem;
  }

  /* Article prose styles */
  .article-content {
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3) {
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 2rem 0 1rem;
  }
  .article-content :global(h1) { font-size: 1.6rem; }
  .article-content :global(h2) { font-size: 1.3rem; }
  .article-content :global(h3) { font-size: 1.1rem; }
  .article-content :global(p) { margin-bottom: 1.2rem; }
  .article-content :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--border-accent);
    transition: opacity 0.2s;
  }
  .article-content :global(a:hover) { opacity: 0.7; }
  .article-content :global(strong) { color: var(--text-primary); font-weight: 500; }
  .article-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--accent);
  }
  .article-content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .article-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .article-content :global(li) { margin-bottom: 0.4rem; }
  .article-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
    display: block;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Light mode */
  html.light .article { background: rgba(255,255,255,0.85) !important; color: var(--text-primary) !important; }
  html.light .article-title { color: #1a1a2e !important; }
  html.light .article-content { color: #333 !important; }
  html.light .article-content h1,
  html.light .article-content h2,
  html.light .article-content h3 { color: #1a1a2e !important; }
  html.light .article-content code { background: rgba(124,111,248,0.08) !important; color: #6c4ff8 !important; }
  html.light .article-content pre { background: rgba(0,0,0,0.06) !important; border-color: rgba(0,0,0,0.12) !important; }
  html.light .article-content pre code { color: #333 !important; }
  html.light .article-content table { border-color: rgba(0,0,0,0.1) !important; }
  html.light .article-content th { background: rgba(124,111,248,0.1) !important; color: #1a1a2e !important; }
  html.light .article-content td, html.light .article-content tr { border-color: rgba(0,0,0,0.1) !important; }
  html.light .tag { background: rgba(124,111,248,0.1) !important; color: #7c6ff8 !important; }
  html.light .back-link { color: #7c6ff8 !important; }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .article-wrapper { padding: 1rem 1rem 3rem !important; }
    .article { max-width: 100% !important; }
    .article-title { font-size: 1.4rem !important; }
    .article-desc { font-size: 0.9rem !important; }
    .article-content { font-size: 0.88rem !important; line-height: 1.8 !important; padding-top: 1.5rem !important; }
    .article-content :global(h1) { font-size: 1.3rem !important; }
    .article-content :global(h2) { font-size: 1.1rem !important; }
    .article-content :global(h3) { font-size: 1rem !important; }
    .article-content :global(p) { margin-bottom: 1rem !important; font-size: 0.88rem !important; }
    .article-content :global(pre) { padding: 0.75rem !important; font-size: 0.78rem !important; margin: 1rem 0 !important; border-radius: 6px !important; }
    .article-content :global(code) { font-size: 0.8em !important; }
    .article-content :global(table) { font-size: 0.8rem !important; overflow-x: auto !important; display: block !important; }
    .article-content :global(img) { max-width: 100% !important; width: 100% !important; height: auto !important; border-radius: 8px !important; margin: 0.5rem 0 !important; }
    .article-content :global(ul), .article-content :global(ol) { padding-left: 1.2rem !important; margin-bottom: 1rem !important; }
    .article-content :global(li) { font-size: 0.88rem !important; margin-bottom: 0.3rem !important; }
  }
  @media (max-width: 480px) {
    .article-wrapper { padding: 0.75rem 0.75rem 2.5rem !important; }
    .article-content { font-size: 0.85rem !important; }
    .article-title { font-size: 1.2rem !important; }
    .article-content :global(pre) { font-size: 0.72rem !important; padding: 0.5rem !important; }
    .article-content :global(h1) { font-size: 1.2rem !important; }
    .article-content :global(h2) { font-size: 1rem !important; }
  }
</style>

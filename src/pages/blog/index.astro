---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const techPosts = allPosts.filter(p => p.data.category === 'Tech');
const essayPosts = allPosts.filter(p => p.data.category === 'Essay');
const paperPosts = allPosts.filter(p => p.data.category === 'Paper');
---
<Layout title="Blog">
  <div class="page-wrapper">
    <div class="page-header">
      <h1 class="page-title">Blog</h1>
      <p class="page-desc">Notes &amp; Technical Exploration</p>
    </div>

    <div class="tab-nav">
      <button class="tab-btn active" data-cat="all">All</button>
      <button class="tab-btn" data-cat="Tech">Tech</button>
      <button class="tab-btn" data-cat="Essay">Essay</button>
      <button class="tab-btn" data-cat="Paper">Paper</button>
    </div>

    <div class="tab-content" id="tab-all">
      <div class="posts">
        {allPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <span class="cat-badge">{post.data.category}</span>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="cat-badge">{post.data.category}</span>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="post-tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="tab-content" id="tab-Tech" style="display:none">
      <div class="posts">
        {techPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <span class="cat-badge">{post.data.category}</span>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="cat-badge">{post.data.category}</span>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="post-tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="tab-content" id="tab-Essay" style="display:none">
      <div class="posts">
        {essayPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <span class="cat-badge">{post.data.category}</span>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="cat-badge">{post.data.category}</span>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="post-tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="tab-content" id="tab-Paper" style="display:none">
      <div class="posts">
        {paperPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <span class="cat-badge">{post.data.category}</span>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="cat-badge">{post.data.category}</span>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => <span class="post-tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b === btn));
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = c.id === `tab-${cat}` ? '' : 'none');
    });
  });
</script>

<style>
  .page-wrapper { max-width: 720px; margin: 0 auto; padding: 3rem 2rem 5rem; animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .page-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .page-title { font-size: 2.2rem; font-weight: 600; letter-spacing: -0.03em; color: var(--text-primary); margin-bottom: 0.5rem; }
  .page-desc { color: var(--text-secondary); font-size: 0.95rem; font-weight: 300; }
  .tab-nav { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .tab-btn {
    padding: 0.4rem 1rem; border-radius: 8px; border: 1px solid var(--border);
    background: transparent; color: var(--text-muted); font-size: 0.85rem;
    cursor: pointer; transition: all 0.2s; font-family: inherit;
  }
  .tab-btn:hover { border-color: var(--accent); color: var(--accent); }
  .tab-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .posts { display: flex; flex-direction: column; gap: 1rem; }
  .post-card { display: block; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; text-decoration: none; transition: all 0.25s ease; }
  .post-card:hover { border-color: var(--border-accent); background: var(--bg-card-hover); transform: translateX(4px); }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
  .post-meta time { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-muted); }
  .cat-badge {
    font-size: 0.7rem; padding: 0.1rem 0.5rem; border-radius: 4px;
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    color: var(--accent); font-family: 'JetBrains Mono', monospace;
  }
  .post-title { font-size: 1.15rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.4rem; letter-spacing: -0.01em; word-break: break-word; }
  .post-desc { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.6; font-weight: 300; margin-bottom: 0.75rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .post-tag { background: var(--accent-dim); border: 1px solid var(--border-accent); color: var(--text-muted); padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; }
  @media (max-width: 768px) {
    .page-wrapper { padding: 1.5rem 1rem 3rem !important; }
    .page-title { font-size: 1.8rem !important; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <div class="page-wrapper">
    <div class="header">
      <div class="header-label">Portfolio</div>
    </div>
    <div class="card">
      <div class="card-inner">
        <div class="profile">
          <div class="avatar-wrap">
            <img src="https://avatars.githubusercontent.com/u/49972575?v=4" alt="Kagura Tart" class="avatar" />
            <span class="avatar-status"></span>
          </div>
          <div class="profile-info">
            <h1 class="profile-name">Kagura Tart</h1>
            <div class="profile-handle">@KaguraTart</div>
            <p class="profile-tagline">Grad student · Autonomous Driving &amp; Transportation</p>
          </div>
        </div>

        <div class="divider"></div>

        <div class="about">
          <div class="about-label">About</div>
          <p class="about-text">
            是蛋挞！<br>
            Researching <strong>autonomous driving</strong> and <strong>intelligent transportation</strong> — building tools that make mobility more comfortable and coding more intuitive.
          </p>
        </div>

        <div class="tags-section">
          <div class="tags-label">Interests</div>
          <div class="tags">
            <span class="tag">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"/><polygon points="12 15 17 21 7 21 12 15"/></svg>
              Autonomous Driving
            </span>
            <span class="tag">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              C / C++
            </span>
            <span class="tag">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>
              Python
            </span>
            <span class="tag">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 6v12M6 12h12"/></svg>
              Traffic Simulation
            </span>
          </div>
        </div>

        <div class="footer">
          <a href="https://github.com/KaguraTart" target="_blank" class="link">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="mailto:kaguratart@gmail.com" class="link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
          <a href="/blog" class="link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
            Blog
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .header { margin-bottom: 2rem; }
  .header-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    animation: fadeUp 0.6s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .header-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--accent);
    opacity: 0.6;
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    overflow: hidden;
    animation: fadeUp 0.8s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .card-inner { padding: 2.5rem; }
  .profile {
    display: flex;
    align-items: flex-start;
    gap: 1.75rem;
    margin-bottom: 2rem;
  }
  .avatar-wrap {
    flex-shrink: 0;
    position: relative;
  }
  .avatar-wrap::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), #a855f7, #ec4899, var(--accent));
    animation: spin 6s linear infinite;
  }
  .avatar-wrap::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), #a855f7, #ec4899, var(--accent));
    animation: spin 6s linear infinite;
    filter: blur(8px);
    opacity: 0.5;
  }
  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    position: relative;
    z-index: 1;
    border: 2px solid var(--bg-base);
    display: block;
  }
  .avatar-status {
    position: absolute;
    bottom: 2px;
    right: 2px;
    z-index: 2;
    width: 14px;
    height: 14px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--bg-base);
    box-shadow: 0 0 8px rgba(34,197,94,0.5);
  }
  .profile-info { flex: 1; padding-top: 0.25rem; }
  .profile-name {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
    line-height: 1.2;
  }
  .profile-handle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--accent);
    opacity: 0.8;
    margin-bottom: 0.75rem;
  }
  .profile-tagline {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
  }
  .divider { height: 1px; background: var(--border); margin: 0.25rem 0 1.75rem; }
  .about-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }
  .about-text {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.85;
    font-weight: 300;
  }
  .about-text strong { color: var(--text-primary); font-weight: 500; }
  .tags-section { margin-top: 2rem; }
  .tags-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    color: var(--text-secondary);
    padding: 0.35rem 0.85rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 400;
    transition: all 0.2s ease;
    cursor: default;
  }
  .tag:hover {
    background: rgba(124,111,248,0.2);
    color: var(--text-primary);
    border-color: rgba(124,111,248,0.5);
    transform: translateY(-1px);
  }
  .tag svg { width: 14px; height: 14px; flex-shrink: 0; }
  .footer { margin-top: 2rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.25s ease;
  }
  .link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    box-shadow: 0 4px 20px var(--accent-glow);
    transform: translateY(-2px);
  }
  .link svg { width: 16px; height: 16px; flex-shrink: 0; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @media (max-width: 520px) {
    .profile { flex-direction: column; align-items: center; text-align: center; }
    .profile-handle { margin-bottom: 0.5rem; }
    .tags { justify-content: center; }
    .footer { justify-content: center; }
    .card-inner { padding: 2rem 1.5rem; }
  }
</style>

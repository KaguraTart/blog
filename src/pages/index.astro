---
import Layout from '../layouts/Layout.astro';
import { profile } from '../config';
import { getCollection } from 'astro:content';

const aboutHtml = profile.about.replace(/\n/g, '<br>');

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout title="Home">
  <div class="page-wrapper">
    <div class="card">
      <div class="card-inner">
        <div class="profile">
          <div class="avatar-wrap">
            <div class="avatar-glow"></div>
            <img src={profile.avatar} alt={profile.name} class="avatar" />
            <div class="avatar-ring"></div>
            <span class="avatar-status"></span>
          </div>
          <div class="profile-info">
            <h1 class="profile-name">{profile.name}</h1>
            <div class="profile-aka">{profile.aka}</div>
            <p class="profile-tagline">{profile.tagline}</p>
          </div>
        </div>

        <div class="divider"></div>

        <div class="about">
          <div class="about-label">About</div>
          <p class="about-text" set:html={aboutHtml} />
        </div>

        <div class="tags-section">
          <div class="tags-label">Interests</div>
          <div class="tags">
            {profile.interests.map(item => (
              <div class="tag">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  {item.icon === 'car' && <><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"/><polygon points="12 15 17 21 7 21 12 15"/></>}
                  {item.icon === 'code' && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
                  {item.icon === 'python' && <><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/></>}
                  {item.icon === 'traffic' && <><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 6v12M6 12h12"/></>}
                  {item.icon === 'uav' && <><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></>}
                  {item.icon === 'llm' && <><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></>}
                </svg>
                {item.label}
              </div>
            ))}
          </div>
        </div>

        {recentPosts.length > 0 && (
          <>
            <div class="posts-divider"></div>
            <div class="recent-posts">
              <div class="recent-header">
                <span class="posts-label">Recent Posts</span>
                <a href="/blog" class="view-all">View All →</a>
              </div>
              <div class="posts-list">
                {recentPosts.map(post => (
                  <a href={`/blog/${post.slug}`} class="post-item">
                    <div class="post-left">
                      <span class="post-day">{post.data.pubDate.getDate().toString().padStart(2, '0')}</span>
                      <span class="post-month">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short' })}</span>
                    </div>
                    <div class="post-title">{post.data.title}</div>
                    {post.data.tags.length > 0 && (
                      <div class="post-tags">
                        <span class="post-tag">{post.data.category}</span>
                      </div>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </>
        )}
      </div>
    </div>
  </div>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.tag, .action-link, .post-item').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>

<style>
  .page-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem 3rem;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .card {
    width: 100%;
    max-width: 640px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    animation: fadeUp 0.8s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .card-inner { padding: 2.5rem; }

  .profile { display: flex; align-items: center; gap: 2rem; margin-bottom: 1.75rem; }
  .avatar-wrap {
    flex-shrink: 0;
    position: relative;
    width: 96px;
    height: 96px;
  }
  .avatar-glow {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,111,248,0.2) 0%, transparent 70%);
    animation: glowPulse 3s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  .avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: linear-gradient(var(--bg-base), var(--bg-base)) padding-box,
                linear-gradient(135deg, var(--accent), #a855f7, #ec4899, var(--accent)) border-box;
    animation: spin 8s linear infinite;
  }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .avatar {
    width: 96px; height: 96px;
    border-radius: 50%;
    position: relative; z-index: 1;
    border: 3px solid var(--bg-base);
    display: block; object-fit: cover;
    transition: transform 0.3s ease;
  }
  .avatar-wrap:hover .avatar { transform: scale(1.06); }
  .avatar-status {
    position: absolute; bottom: 3px; right: 3px; z-index: 2;
    width: 15px; height: 15px;
    background: #22c55e; border-radius: 50%;
    border: 3px solid var(--bg-base);
    box-shadow: 0 0 10px rgba(34,197,94,0.5);
    animation: statusPulse 2s ease-in-out infinite;
  }
  @keyframes statusPulse {
    0%, 100% { box-shadow: 0 0 6px rgba(34,197,94,0.4); }
    50% { box-shadow: 0 0 14px rgba(34,197,94,0.7); }
  }

  .profile-info { flex: 1; }
  .profile-name {
    font-size: 1.7rem; font-weight: 700;
    letter-spacing: -0.04em; color: var(--text-primary);
    line-height: 1.1; margin-bottom: 0.2rem;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .profile-handle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem; color: var(--accent); opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  .profile-aka {
    font-size: 0.82rem; color: var(--text-muted);
    margin-bottom: 0.2rem; font-weight: 300;
  }
  .profile-tagline {
    font-size: 0.88rem; color: var(--text-secondary);
    font-weight: 300; line-height: 1.5;
  }

  .divider { height: 1px; background: var(--border); margin: 0 0 1.5rem; }

  .about-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
    margin-bottom: 0.6rem;
  }
  .about-text {
    font-size: 0.92rem; color: var(--text-secondary);
    line-height: 1.85; font-weight: 300;
  }

  .tags-section { margin-top: 1.75rem; }
  .tags-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    color: var(--text-secondary); padding: 0.35rem 0.9rem;
    border-radius: 8px; font-size: 0.8rem; font-weight: 400;
    cursor: default; overflow: hidden; position: relative;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .tag .shine {
    position: absolute; top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(124,111,248,0.1), transparent);
    transition: left 0.5s ease;
  }
  .tag:hover {
    background: rgba(124,111,248,0.2); color: var(--text-primary);
    border-color: rgba(124,111,248,0.5); transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(124,111,248,0.2);
  }
  .tag:hover .shine { left: 150%; }
  .tag svg { width: 14px; height: 14px; flex-shrink: 0; color: var(--accent); transition: color 0.2s; }
  .tag:hover svg { color: var(--text-primary); }

  .footer-links { margin-top: 2rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .action-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    color: var(--text-secondary); text-decoration: none;
    padding: 0.65rem 1.2rem; border-radius: 10px; font-size: 0.85rem; font-weight: 500;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .action-link svg { width: 16px; height: 16px; }
  .action-link.github:hover { background: #24292e; color: #fff; border-color: #24292e; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(36,41,46,0.4); }
  .action-link.email:hover { background: var(--accent); color: #fff; border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 6px 20px var(--accent-glow); }
  .action-link.blog:hover { background: rgba(34,197,94,0.15); color: #22c55e; border-color: rgba(34,197,94,0.3); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(34,197,94,0.15); }

  .posts-divider { height: 1px; background: var(--border); margin: 1.75rem 0 1.5rem; }
  .recent-posts {}
  .posts-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
    margin-bottom: 0.85rem;
  }
  .posts-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .post-item {
    display: flex; align-items: center; gap: 1rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 0.85rem 1.2rem;
    text-decoration: none; transition: all 0.3s ease;
    position: relative; overflow: hidden;
  }
  .post-item::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(to bottom, var(--accent), #a855f7);
    opacity: 0; transition: opacity 0.3s;
  }
  .post-item:hover {
    border-color: var(--border-accent); background: var(--bg-card-hover);
    transform: translateX(5px); box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .post-item:hover::before { opacity: 1; }
  .post-left {
    display: flex; flex-direction: column; align-items: center;
    min-width: 38px; flex-shrink: 0;
  }
  .post-day {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem; font-weight: 600; color: var(--text-primary); line-height: 1;
  }
  .post-month { color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.05em;
  }
  .post-title {
    flex: 1; font-size: 0.88rem; color: var(--text-secondary);
    transition: color 0.2s;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-item:hover .post-title { color: var(--text-primary); }
  .post-tags { flex-shrink: 0; }
  .post-tag {
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    color: var(--text-secondary); padding: 0.15rem 0.5rem;
    border-radius: 5px; font-size: 0.7rem;
  }
  .post-item { flex-wrap: wrap; }
  .post-tags { margin-top: 0.25rem; }

  /* Reveal animations */
  .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.5s, transform 0.5s; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 520px) {
    .profile { flex-direction: column; text-align: center; gap: 1.25rem; }
    .profile-handle { margin-bottom: 0.25rem; }
    .footer-links { justify-content: center; }
    .card-inner { padding: 2rem 1.5rem; }
    .tags { justify-content: center; }
  }

  /* Recent posts header */
  .recent-header {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.85rem;
  }
  .view-all {
    font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
    color: var(--accent); text-decoration: none; letter-spacing: 0.05em;
    transition: opacity 0.2s;
  }
  .view-all:hover { opacity: 0.7; }

</style>

---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Search" description="Search the blog">
  <div class="search-wrapper">
    <header class="search-header">
      <h1 class="search-title">Search</h1>
      <p class="search-desc">Find posts, papers and notes</p>
    </header>

    <div class="search-box">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="Search posts..."
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-clear" class="search-clear" aria-label="Clear" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M18 6 6 18M6 6 18"/>
        </svg>
      </button>
    </div>

    <div id="search-results" class="search-results">
      <div id="search-empty" class="search-empty">
        <p>Type to search across all posts</p>
      </div>
      <div id="search-loading" class="search-loading" style="display:none">
        <div class="loading-dots"><span></span><span></span><span></span></div>
      </div>
      <div id="search-no-results" class="search-empty" style="display:none">
        <p>No results found — <span id="query-text"></span></p>
      </div>
      <div id="search-list" class="search-list"></div>
    </div>
  </div>
</Layout>

<script>
  let pagefind: any = null;

  async function loadPagefind() {
    try {
      // @ts-ignore
      const pf = await import('/pagefind/pagefind.js');
      await pf.init();
      pagefind = pf;
    } catch (e) {
      console.warn('Pagefind not available:', e);
    }
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function highlight(text: string, query: string) {
    if (!query.trim()) return text;
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
  }

  async function doSearch(query: string) {
    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
    const emptyState = document.getElementById('search-empty') as HTMLDivElement;
    const loading = document.getElementById('search-loading') as HTMLDivElement;
    const noResults = document.getElementById('search-no-results') as HTMLDivElement;
    const queryText = document.getElementById('query-text') as HTMLSpanElement;
    const list = document.getElementById('search-list') as HTMLDivElement;

    clearBtn.style.display = query ? '' : 'none';
    emptyState.style.display = query ? 'none' : '';
    noResults.style.display = 'none';
    list.innerHTML = '';

    if (!query.trim()) {
      emptyState.querySelector('p')!.textContent = 'Type to search across all posts';
      return;
    }

    emptyState.style.display = 'none';
    loading.style.display = '';

    if (!pagefind) {
      loading.style.display = 'none';
      emptyState.querySelector('p')!.textContent = 'Search index loading, please try again...';
      emptyState.style.display = '';
      return;
    }

    try {
      const results = await pagefind.search(query);
      loading.style.display = 'none';

      if (results.results.length === 0) {
        queryText.textContent = `"${query}"`;
        noResults.style.display = '';
        return;
      }

      const topResults = results.results.slice(0, 8);
      const dataList = await Promise.all(topResults.map((r: any) => r.data()));

      list.innerHTML = dataList.map((item: any) => {
        const rawExcerpt = (item.excerpt || '').replace(/<[^>]+>/g, '').slice(0, 200);
        const excerpt = rawExcerpt ? highlight(escapeHtml(rawExcerpt) + '...', query) : '';
        const title = highlight(escapeHtml(item.meta && item.meta.title ? item.meta.title : item.url), query);
        return `
          <a href="${item.url}" class="result-card">
            <h2 class="result-title">${title}</h2>
            ${excerpt ? `<p class="result-excerpt">${excerpt}</p>` : ''}
            <span class="result-link">Read more →</span>
          </a>`;
      }).join('');

    } catch (err) {
      loading.style.display = 'none';
      emptyState.querySelector('p')!.textContent = 'Search failed, please try again.';
      emptyState.style.display = '';
    }
  }

  let debounceTimer: ReturnType<typeof setTimeout>;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(input.value), 200);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.style.display = 'none';
    doSearch('');
    input.focus();
  });

  loadPagefind();
</script>

<style>
  .search-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .search-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .search-title {
    font-size: 2.2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .search-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 300;
  }

  .search-box {
    position: relative;
    margin-bottom: 2rem;
  }
  .search-icon {
    position: absolute;
    left: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--text-muted);
    pointer-events: none;
    transition: color 0.2s;
    z-index: 1;
  }
  .search-box:focus-within .search-icon {
    color: var(--accent);
  }
  .search-input {
    width: 100%;
    padding: 1rem 3.5rem 1rem 3rem;
    font-size: 1rem;
    font-family: inherit;
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    -webkit-appearance: none;
  }
  .search-input::placeholder {
    color: var(--text-muted);
  }
  .search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(124, 111, 248, 0.12);
  }
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-clear {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: var(--bg-card-hover);
    border-radius: 50%;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.2s;
    z-index: 1;
  }
  .search-clear svg { width: 12px; height: 12px; }
  .search-clear:hover { background: var(--border); color: var(--text-primary); }

  .search-results { min-height: 200px; }
  .search-empty {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .search-loading {
    display: flex;
    justify-content: center;
    padding: 3rem;
  }
  .loading-dots {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .loading-dots span {
    width: 8px; height: 8px;
    background: var(--accent);
    border-radius: 50%;
    animation: dotPulse 1.4s ease-in-out infinite;
  }
  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dotPulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }

  .search-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .result-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .result-card:hover {
    border-color: var(--border-accent);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .result-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }
  .result-excerpt {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }
  .result-link {
    font-size: 0.8rem;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }

  :global(mark) {
    background: rgba(124, 111, 248, 0.25);
    color: var(--accent);
    border-radius: 2px;
    padding: 0 2px;
  }
  :global(html.light) mark {
    background: rgba(124, 111, 248, 0.15);
    color: #5a4fcf;
  }

  @media (max-width: 768px) {
    .search-wrapper { padding: 1.5rem 1rem 3rem !important; }
    .search-title { font-size: 1.8rem !important; }
  }
</style>
